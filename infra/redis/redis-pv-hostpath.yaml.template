apiVersion: v1
kind: PersistentVolume
metadata:
  name: redis-pv-hostpath
  labels:
    app: redis
    component: storage
    storage-type: hostpath
    app.kubernetes.io/part-of: pasb
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: hostpath-storage
  hostPath:
    path: "[CLUSTER_BASE_PATH]/redis"
    type: DirectoryOrCreate
